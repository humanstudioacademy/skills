---
/*
  Work Grid — cards de projetos em grid editorial.

  Layouts (responde ao inventário real de assets):
    - "3-col"           — 3 cards por linha (briefings com 4+ projetos)
    - "2-col"           — 2 cards por linha (briefings com 2-3 projetos)
    - "stacked"         — lista vertical (briefings com leitura editorial narrativa)
    - "single-feature"  — 1 projeto destaque grande + copy editorial (1 projeto real)

  Quando um projeto não tem mediaSrc, usa PlaceholderEditorial (tipografia-como-mídia).
  Se o briefing tem **só 1 projeto real**, use layout "single-feature" em vez de
  preencher com placeholders — ver feedback_templates_moldaveis_ao_conteudo em memory.
*/
import Marker from '@components/base/Marker.astro';
import PlaceholderEditorial from '@components/base/PlaceholderEditorial.astro';

export interface WorkProject {
  marker: string;
  title: string;
  client?: string;
  year?: string;
  services?: string[];
  mediaSrc?: string;      // opcional — se ausente, renderiza PlaceholderEditorial
  mediaAlt?: string;
  href?: string;
}

interface Props {
  id?: string;
  marker?: string;
  markerLabel?: string;
  heading: string;
  projects: WorkProject[];
  layout?: '3-col' | '2-col' | 'stacked' | 'single-feature';
  cardAspect?: '4/5' | '3/2' | '1/1' | '3/4';
}
const {
  id,
  marker = '03',
  markerLabel = 'Selected work',
  heading,
  projects,
  layout = '3-col',
  cardAspect = '4/5',
} = Astro.props;

const aspectClass = {
  '4/5': 'aspect-[4/5]',
  '3/2': 'aspect-[3/2]',
  '1/1': 'aspect-square',
  '3/4': 'aspect-[3/4]',
}[cardAspect];

const gridClass = {
  '3-col': 'grid-cols-1 md:grid-cols-2 lg:grid-cols-3',
  '2-col': 'grid-cols-1 md:grid-cols-2',
  'stacked': 'grid-cols-1',
  'single-feature': 'grid-cols-1',
}[layout];
---
<section id={id} class="bg-[var(--color-bg)]">
  <div class="mx-auto max-w-[var(--content-max)] px-[var(--gutter)] pb-[var(--space-24)]">
    <div class="mb-[var(--space-10)] grid grid-cols-12 items-end gap-[var(--gutter)] border-t border-[var(--color-rule)] pt-[var(--space-6)]">
      <div class="reveal col-span-12 md:col-span-3"><Marker value={marker} variant="paren" label={markerLabel} /></div>
      <h2 class="reveal col-span-12 md:col-span-9 font-[family-name:var(--font-display)] text-[length:var(--text-xl)] md:text-[length:var(--text-2xl)] font-bold leading-[var(--leading-heading)] tracking-[var(--tracking-tight)] text-[var(--color-ink)]">
        {heading}
      </h2>
    </div>

    <div class={`stagger-children grid gap-x-[var(--gutter)] gap-y-[var(--space-10)] ${gridClass}`}>
      {projects.map((p) => (
        <a href={p.href ?? '#'} class="group block" data-magnetic="0.05">
          <div class="mb-4 flex items-start justify-between text-[var(--color-ink-dim)]">
            <span class="label-caps text-[var(--color-ink-mute)]">(<span data-counter-hover>{p.marker}</span>)</span>
            {p.year && <span class="label-caps">{p.year}</span>}
          </div>

          {p.mediaSrc ? (
            <figure class={`relative ${aspectClass} overflow-hidden bg-[var(--color-bg-alt)]`}>
              <img
                src={p.mediaSrc}
                alt={p.mediaAlt ?? p.title}
                class="h-full w-full object-cover transition-transform duration-[var(--duration-epic)] ease-[var(--ease-out-expo)] group-hover:scale-[1.04]"
              />
              <div class="pointer-events-none absolute inset-0 bg-[var(--color-accent)] opacity-0 mix-blend-multiply transition-opacity duration-[var(--duration-base)] group-hover:opacity-15"></div>
            </figure>
          ) : (
            <div class="transition-transform duration-[var(--duration-epic)] ease-[var(--ease-out-expo)] group-hover:scale-[1.04]">
              <PlaceholderEditorial marker={p.marker} name={p.title} aspect={cardAspect} />
            </div>
          )}

          <div class="mt-4 flex items-start justify-between gap-4">
            <div>
              <h3 class="font-[family-name:var(--font-display)] text-[length:var(--text-md)] font-bold leading-tight tracking-[var(--tracking-tight)] text-[var(--color-ink)] transition-colors duration-[var(--duration-base)] group-hover:text-[var(--color-accent)]">
                {p.title}
              </h3>
              {p.client && (
                <p class="mt-1 text-[length:var(--text-sm)] text-[var(--color-ink-dim)]">{p.client}</p>
              )}
            </div>
            {p.services && p.services.length > 0 && (
              <ul class="hidden md:flex shrink-0 flex-col items-end gap-1 text-right label-caps text-[var(--color-ink-mute)]">
                {p.services.slice(0, 3).map((s) => <li>{s}</li>)}
              </ul>
            )}
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
