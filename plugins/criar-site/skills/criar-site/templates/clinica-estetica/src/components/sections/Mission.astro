---
/*
  Mission — statement centralizado respirado.
  Signature: marker small caps + rule + serif italic mesclado com roman.
*/
import Marker from '@components/base/Marker.astro';

interface Props {
  marker?: string;           // "MISSION" | "OUR PHILOSOPHY"
  heading: string;           // frase principal
  headingItalic?: string;    // parte em italic final
  body?: string;
  id?: string;
}
const { marker = 'MISSION', heading, headingItalic, body, id } = Astro.props;
---
<section id={id} class="bg-[var(--color-bg-alt)]">
  <div class="mx-auto max-w-3xl px-[var(--gutter)] py-[var(--space-20)] text-center">
    <div class="reveal mb-6 flex justify-center">
      <Marker label={marker} align="center" rule />
    </div>

    <h2 class="font-[family-name:var(--font-display)] text-[length:var(--text-xl)] md:text-[length:var(--text-2xl)] font-normal leading-[var(--leading-heading)] tracking-[var(--tracking-snug)] text-[var(--color-deep)]" data-italic-reveal>
      {heading}
      {headingItalic && <> <span class="italic-emphasis">{headingItalic}</span></>}
    </h2>

    {body && (
      <p class="reveal mx-auto mt-6 max-w-xl text-[length:var(--text-base)] leading-[var(--leading-body)] text-[var(--color-ink-dim)]">
        {body}
      </p>
    )}
  </div>
</section>
