---
/*
  Footer — minimal editorial com metadata e info.
  Signature: rule ink + colunas tipográficas + label-caps.
*/
interface NavGroup {
  label: string;
  links: { label: string; href: string }[];
}
interface MetaItem {
  key: string;
  value: string;
}

interface Props {
  brand: string;
  tagline?: string;
  navGroups?: NavGroup[];
  meta?: MetaItem[];
  colophon?: string;
}
const { brand, tagline, navGroups = [], meta = [], colophon } = Astro.props;
---
<footer class="border-t border-[var(--color-rule)] bg-[var(--color-bg)]">
  <div class="mx-auto max-w-[var(--content-max)] px-[var(--gutter)] py-[var(--space-12)]">
    <div class="grid grid-cols-12 gap-[var(--gutter)]">
      <div class="col-span-12 md:col-span-5">
        <p class="font-[family-name:var(--font-display)] text-[length:var(--text-lg)] font-bold tracking-[var(--tracking-tight)] text-[var(--color-ink)]">
          {brand}
        </p>
        {tagline && (
          <p class="mt-3 max-w-sm text-[length:var(--text-base)] leading-[var(--leading-body)] text-[var(--color-ink-dim)]">
            {tagline}
          </p>
        )}
      </div>

      <div class="col-span-12 md:col-span-7 grid grid-cols-2 md:grid-cols-3 gap-[var(--gutter)]">
        {navGroups.map((group) => (
          <div>
            <p class="label-caps mb-3 text-[var(--color-ink-mute)]">{group.label}</p>
            <ul class="flex flex-col gap-2">
              {group.links.map((l) => (
                <li>
                  <a href={l.href} class="text-[length:var(--text-base)] text-[var(--color-ink)] link-ink">
                    {l.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>

    {(meta.length > 0 || colophon) && (
      <div class="mt-[var(--space-10)] grid grid-cols-12 items-end gap-[var(--gutter)] border-t border-[var(--color-rule-soft)] pt-[var(--space-4)]">
        <ul class="col-span-12 md:col-span-8 flex flex-wrap gap-x-8 gap-y-1">
          {meta.map((m) => (
            <li class="label-caps text-[var(--color-ink-mute)]">
              <span>{m.key}:</span>{' '}
              <span class="text-[var(--color-ink-dim)]">{m.value}</span>
            </li>
          ))}
        </ul>
        {colophon && (
          <p class="col-span-12 md:col-span-4 label-caps text-right text-[var(--color-ink-mute)]">
            {colophon}
          </p>
        )}
      </div>
    )}
  </div>
</footer>
